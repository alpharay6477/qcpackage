# ======================
# 检查 gjf 有几个片段，及其对应序号

# 共价半径（Å）
# ======================
COVALENT_RADII = {
    "H": 0.31, "He": 0.28,
    "Li": 1.28, "Be": 0.96, "B": 0.84, "C": 0.76, "N": 0.71, "O": 0.66,
    "F": 0.57, "Ne": 0.58,
    "Na": 1.66, "Mg": 1.41, "Al": 1.21, "Si": 1.11, "P": 1.07,
    "S": 1.05, "Cl": 1.02, "Ar": 1.06,
    "K": 2.03, "Ca": 1.76,
    "Sc": 1.70, "Ti": 1.60, "V": 1.53, "Cr": 1.39,
    "Mn": 1.39, "Fe": 1.32, "Co": 1.26, "Ni": 1.24,
    "Cu": 1.32, "Zn": 1.22,
    "Br": 1.20, "I": 1.39
}

BOND_FACTOR = 1.25


# ======================
# Gaussian 解析
# ======================
def parse_gaussian_input(file_path):
    with open(file_path, 'r') as f:
        lines = f.readlines()

    charge_mult = None
    coords = []
    in_coords = False

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith('!'):
            continue

        parts = stripped.split()

        if charge_mult is None and len(parts) == 2:
            try:
                charge = int(parts[0])
                mult = int(parts[1])
                if mult >= 1:
                    charge_mult = (charge, mult)
                    in_coords = True
                    continue
            except ValueError:
                pass

        if in_coords and len(parts) >= 4:
            if parts[0][0].isalpha():
                try:
                    coords.append(
                        (parts[0],
                         float(parts[1]),
                         float(parts[2]),
                         float(parts[3]))
                    )
                except ValueError:
                    break

    return charge_mult, coords


# ======================
# 成键与片段识别
# ======================
def distance(a, b):
    return math.sqrt(
        (a[1] - b[1]) ** 2 +
        (a[2] - b[2]) ** 2 +
        (a[3] - b[3]) ** 2
    )


def build_bond_graph(coords):
    graph = defaultdict(list)
    n = len(coords)

    for i in range(n):
        ri = COVALENT_RADII.get(coords[i][0], 0.77)
        for j in range(i + 1, n):
            rj = COVALENT_RADII.get(coords[j][0], 0.77)
            if distance(coords[i], coords[j]) <= BOND_FACTOR * (ri + rj):
                graph[i].append(j)
                graph[j].append(i)
    return graph


def find_fragments(graph, n_atoms):
    visited = [False] * n_atoms
    fragments = []

    for i in range(n_atoms):
        if not visited[i]:
            queue = deque([i])
            visited[i] = True
            frag = [i + 1]  # 注意：这里存储的是1-based索引

            while queue:
                v = queue.popleft()
                for nb in graph[v]:
                    if not visited[nb]:
                        visited[nb] = True
                        queue.append(nb)
                        frag.append(nb + 1)

            fragments.append(frag)

    # 按原子个数降序排序（大片段在前）
    fragments.sort(key=lambda x: len(x), reverse=True)

    return fragments


# ======================
# 连续编号压缩
# ======================
def compress_indices(indices):
    if not indices:
        return ""

    # 确保序号是排序的
    indices = sorted(indices)
    ranges = []
    start = prev = indices[0]

    for i in indices[1:]:
        if i == prev + 1:
            prev = i
        else:
            ranges.append((start, prev))
            start = prev = i
    ranges.append((start, prev))

    # 将范围格式化为字符串
    parts = []
    for a, b in ranges:
        if a == b:
            parts.append(str(a))
        else:
            parts.append(f"{a}-{b}")

    return ",".join(parts)


# ======================
# 执行外部命令 - 修复版本
# ======================
def run_mcubegen(cmd, filename):
    """执行MCubeGen.py命令"""
    print(f"  执行MCubeGen.py: {cmd}")
    
    # 确保MCUBEG目录存在（在命令执行前创建）
    mcubeg_dir = "MCUBEG"
    os.makedirs(mcubeg_dir, exist_ok=True)
    
    try:
        # 使用更详细的执行方式
        process = subprocess.Popen(
            cmd,
            shell=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            universal_newlines=True
        )
        
        # 收集输出
        stdout_lines = []
        stderr_lines = []
        
        # 读取输出
        for line in process.stdout:
            stdout_lines.append(line)
            if 'moved to' in line or 'Progress:' in line:
                print(f"    {line.strip()}")
        
        for line in process.stderr:
            stderr_lines.append(line)
            if line.strip():
                print(f"    [stderr] {line.strip()}")
        
        # 等待进程完成
        process.wait()
        returncode = process.returncode
        
        stdout = ''.join(stdout_lines)
        stderr = ''.join(stderr_lines)
        
        if returncode == 0:
            print(f"  ✓ MCubeGen.py执行成功")
            
            # 检查是否生成了cub文件
            if 'moved to' in stdout:
                # 解析移动的文件
                moved_files = []
                for line in stdout.split('\n'):
                    if 'moved to' in line:
                        parts = line.strip().split()
                        if parts:
                            moved_files.append(parts[0])
                
                if moved_files:
                    print(f"  📦 生成的cub文件: {', '.join(moved_files)}")
                else:
                    print(f"  ⚠️  没有找到移动文件的信息")
            
            # 检查MCUBEG目录
            cub_files = [f for f in os.listdir(mcubeg_dir) if f.endswith('.cub')]
            if cub_files:
                print(f"  📂 MCUBEG目录中有 {len(cub_files)} 个.cub文件")
                matching_cubs = [cub for cub in cub_files if filename in cub]
                if matching_cubs:
                    print(f"  ✅ 找到 {len(matching_cubs)} 个匹配的cub文件")
                    for cub in matching_cubs[:3]:  # 只显示前3个
                        print(f"    • {cub}")
                    if len(matching_cubs) > 3:
                        print(f"    • ... 还有 {len(matching_cubs)-3} 个")
                else:
                    print(f"  ⚠️  没有找到与 {filename} 相关的cub文件")
            else:
                print(f"  ⚠️  MCUBEG目录中没有.cub文件")
                
        else:
            print(f"  ✗ MCubeGen.py执行失败 (错误代码: {returncode})")
            if stderr.strip():
                print(f"  错误信息:\n    " + "\n    ".join(stderr.strip().split('\n')[:5]))
        
        return returncode
        
    except Exception as e:
        print(f"  ✗ 执行MCubeGen.py时发生异常: {e}")
        return -1


def run_mfiggen(cmd, filename):
    """执行MFigGen.py命令"""
    print(f"  执行MFigGen.py: {cmd}")
    
    # 确保MFIG目录存在
    mfig_dir = "MFIG"
    os.makedirs(mfig_dir, exist_ok=True)
    
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        
        if result.returncode == 0:
            print(f"  ✓ MFigGen.py执行成功")
            
            # 检查输出中是否有移动文件的信息
            if 'moved to' in result.stdout:
                for line in result.stdout.split('\n'):
                    if 'moved to' in line and filename in line:
                        print(f"    {line.strip()}")
            
            # 检查MFIG目录
            img_files = [f for f in os.listdir(mfig_dir) 
                        if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tiff', '.bmp'))]
            matching_imgs = [img for img in img_files if filename in img]
            
            if matching_imgs:
                print(f"  🖼️  找到 {len(matching_imgs)} 个图片文件")
                for img in matching_imgs[:3]:  # 只显示前3个
                    print(f"    • {img}")
                if len(matching_imgs) > 3:
                    print(f"    • ... 还有 {len(matching_imgs)-3} 个")
            else:
                print(f"  ⚠️  没有找到与 {filename} 相关的图片文件")
                
        else:
            print(f"  ✗ MFigGen.py执行失败 (错误代码: {result.returncode})")
        
        return result.returncode
        
    except Exception as e:
        print(f"  ✗ 执行MFigGen.py时发生异常: {e}")
        return -1


# ======================
# 处理单个文件（串行执行命令）
# ======================
def process_file_serial(filename, fragments_str, fchk_file):
    """串行执行一个文件的两个命令"""
    print(f"\n处理文件: {filename}")
    
    # 构建命令
    cube_cmd = f"MCubeGen.py -f \"{fragments_str}\" -w igmh {fchk_file}"
    fig_cmd = f"MFigGen.py -f \"{fragments_str}\" -t igmh {fchk_file}"
    
    print(f"  MCubeGen.py命令: {cube_cmd}")
    print(f"  MFigGen.py命令: {fig_cmd}")
    
    # 先执行MCubeGen.py
    print(f"\n[1/2] 执行MCubeGen.py...")
    cube_result = run_mcubegen(cube_cmd, filename)
    
    # 等待一下，确保目录稳定
    time.sleep(0.5)
    
    # 再执行MFigGen.py
    print(f"\n[2/2] 执行MFigGen.py...")
    fig_result = run_mfiggen(fig_cmd, filename)
    
    # 检查最终结果
    success = (cube_result == 0 and fig_result == 0)
    
    # 最终检查MCUBEG目录
    mcubeg_dir = "MCUBEG"
    if os.path.exists(mcubeg_dir):
        cub_files = [f for f in os.listdir(mcubeg_dir) if f.endswith('.cub') and filename in f]
        if cub_files:
            print(f"\n✅ 最终确认: 为 {filename} 生成了 {len(cub_files)} 个.cub文件")
        else:
            print(f"\n⚠️  最终确认: 未找到 {filename} 的.cub文件")
    
    return success, cube_result, fig_result


# ======================
# 主流程
# ======================
def main():
    files = [f for f in os.listdir('.') if f.lower().endswith(('.gjf', '.com'))]
    
    if not files:
        print("当前目录下未找到 .gjf 或 .com 文件")
        return

    # 统计处理结果
    total_files = len(files)
    processed_count = 0
    skipped_count = 0
    error_count = 0

    print(f"找到 {total_files} 个文件需要处理")
    print("="*60)

    # 按顺序处理每个文件
    for i, file in enumerate(files, 1):
        print(f"\n{'#'*60}")
        print(f"[{i}/{total_files}] 分析文件: {file}")
        print(f"{'#'*60}")
        
        base = os.path.splitext(file)[0]

        # 解析Gaussian输入文件
        charge_mult, coords = parse_gaussian_input(file)
        if not coords:
            print(f"  ✗ 未找到坐标信息，跳过")
            skipped_count += 1
            continue

        # 分析片段
        graph = build_bond_graph(coords)
        fragments = find_fragments(graph, len(coords))

        filename = os.path.splitext(file)[0]

        print(f"  总原子数: {len(coords)}")
        print(f"  片段数: {len(fragments)}")

        # 为每个片段生成压缩后的原子序号
        compressed_fragments = []
        for idx, frag in enumerate(fragments, 1):
            compressed = compress_indices(frag)
            atom_count = len(frag)
            compressed_fragments.append(compressed)
            print(f"  片段 {idx} ({atom_count} 个原子): {compressed}")

        # 如果片段数大于等于2，执行命令
        if len(fragments) >= 2:
            # 构建片段字符串
            fragments_str = ";".join(compressed_fragments)
            
            # 检查对应的fchk文件是否存在
            fchk_file = f"{filename}.fchk"
            if not os.path.exists(fchk_file):
                print(f"  ✗ 未找到对应的fchk文件 {fchk_file}，跳过")
                skipped_count += 1
                continue
            
            # 串行执行两个命令
            success, cube_result, fig_result = process_file_serial(filename, fragments_str, fchk_file)
            
            # 统计结果
            if success:
                print(f"\n✅ {filename} 处理成功")
                processed_count += 1
            else:
                print(f"\n❌ {filename} 处理失败")
                error_count += 1
        else:
            print(f"  片段数 {len(fragments)} < 2，跳过此文件")
            skipped_count += 1

    # 打印总结
    print(f"\n" + "="*60)
    print("处理完成!")
    print(f"总文件数: {total_files}")
    print(f"成功处理: {processed_count}")
    print(f"跳过文件: {skipped_count}")
    print(f"错误文件: {error_count}")
    
    # 显示目录内容
    for dir_name in ["MCUBEG", "MFIG"]:
        if os.path.exists(dir_name):
            files_in_dir = os.listdir(dir_name)
            if files_in_dir:
                print(f"\n{dir_name} 目录内容 ({len(files_in_dir)} 个文件):")
                
                if dir_name == "MCUBEG":
                    cub_files = [f for f in files_in_dir if f.endswith('.cub')]
                    if cub_files:
                        print(f"  .cub文件: {len(cub_files)} 个")
                        # 按文件前缀分组显示
                        prefix_dict = {}
                        for f in cub_files:
                            prefix = f.split('_')[0]  # 假设文件名格式为 prefix_xxx.cub
                            if prefix not in prefix_dict:
                                prefix_dict[prefix] = []
                            prefix_dict[prefix].append(f)
                        
                        for prefix in sorted(prefix_dict.keys()):
                            files_list = prefix_dict[prefix]
                            print(f"    {prefix}: {len(files_list)} 个文件")
                
                elif dir_name == "MFIG":
                    img_files = [f for f in files_in_dir 
                               if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tiff', '.bmp', '.txt'))]
                    if img_files:
                        print(f"  图片/文本文件: {len(img_files)} 个")
                        # 按文件前缀分组显示
                        prefix_dict = {}
                        for f in img_files:
                            prefix = f.split('_')[0]
                            if prefix not in prefix_dict:
                                prefix_dict[prefix] = []
                            prefix_dict[prefix].append(f)
                        
                        for prefix in sorted(prefix_dict.keys()):
                            files_list = prefix_dict[prefix]
                            print(f"    {prefix}: {len(files_list)} 个文件")
            else:
                print(f"\n{dir_name} 目录为空")
    
    print("="*60)


if __name__ == "__main__":
    main()
