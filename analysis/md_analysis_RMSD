#!/bin/env python

import MDAnalysis as mda
from MDAnalysis.analysis import rms
import numpy as np
import matplotlib.pyplot as plt
import argparse

# 解析命令行参数
parser = argparse.ArgumentParser(description="计算分子片段的 RMSD")
parser.add_argument('-f', "--file", required=True, type=str, help="轨迹文件路径")
parser.add_argument('-p', "--segment", required=True, type=str, help="原子序号，用法“1,22,45,54” 表示片段")

args = parser.parse_args()

# 轨迹文件
traj_file = args.file

# 解析原子序号
def parse_atom_indices(atom_indices_str):
    indices = []
    for part in atom_indices_str.split(','):
        if '-' in part:
            start, end = part.split('-')
            indices.extend(range(int(start), int(end) + 1))
        else:
            indices.append(int(part))
    indices = np.array(indices) - 1  # MDAnalysis 从 0 开始编号
    return indices

# 获取片段原子编号
segment_atoms = parse_atom_indices(args.segment)

# 加载轨迹
u = mda.Universe(traj_file)

# 定义参考状态（通常使用第0帧作为参考）
reference = u.select_atoms('bynum ' + ' '.join(map(str, segment_atoms)))

# 初始化 RMSD 计算器
R = rms.RMSD(u, reference, select='bynum ' + ' '.join(map(str, segment_atoms)))

# 开始计算 RMSD
R.run()

# 提取 RMSD 数据
rmsd = R.rmsd[:, 2]  # 获取所有帧的 RMSD 值，RMSD 数据存储在第二列

# 输出文件名
output_filename = "rmsd_output.txt"

# 将 RMSD 数据写入文件
with open(output_filename, 'w') as f:
    f.write("Frame\tRMSD (Å)\n")
    for idx, rmsd_value in enumerate(rmsd):
        f.write(f"{idx + 1}\t{rmsd_value:.3f}\n")

print(f'RMSD 数据已写入 {output_filename}')

# 绘制 RMSD 随时间变化的图像
plt.figure(figsize=(10, 6))
plt.plot(rmsd, label='RMSD')
plt.xlabel('Frame')
plt.ylabel('RMSD (Å)')
plt.title('RMSD Over Time')
plt.legend()
plt.grid(True)
plt.savefig('rmsd_plot.png')
plt.show()


# 输出文件名
output_filename = "aimd_RMSD.txt"

# 将帧号和 RMSD 数据写入文件，并添加标题行
with open(output_filename, 'w') as f:
    f.write("Frame\tRMSD (Å)\n")  # 写入标题行
    for idx, rmsd_value in enumerate(rmsd):
        f.write(f"{idx + 1}\t{rmsd_value:.3f}\n")  # 写入帧号和对应的 RMSD 值

print(f'RMSD 数据已写入 {output_filename}')

