#!/bin/env python
import sys
import re

def process_file(filename):
    with open(filename, 'r') as f:
        content = f.read()

    # 找到最后一个ORBITAL ENERGIES部分
    orbital_sections = re.findall(r'-+\nORBITAL ENERGIES\n-+\n(.*?)(?:\*Only.*?orbitals were printed\.|\n-+\nTIMINGS)', content, re.DOTALL)
    if not orbital_sections:
        print("未找到ORBITAL ENERGIES部分")
        return
    
    last_section = orbital_sections[-1]
    lines = last_section.strip().split('\n')
    
    # 提取数据
    data = []
    for line in lines[2:]:  # 跳过表头
        if line.strip() and not line.startswith('*'):
            parts = line.split()
            no = int(parts[0])
            occ = float(parts[1])
            e_eh = float(parts[2])
            e_ev = float(parts[3])
            data.append((no, occ, e_eh, e_ev))
    
    if not data:
        print("未找到有效数据")
        return
    
    # 找出OCC下降的点
    drop_points = []
    #print(data)
    for i in range(1, len(data)):
        if data[i][1] < data[i-1][1]:
            drop_points.append(data[i-2])
            drop_points.append(data[i-1])
            drop_points.append(data[i])
            drop_points.append(data[i+1])
    #print(drop_points)
    if len(drop_points) < 2:
        print("未找到足够的OCC下降点")
        return
    
    # 取前二行和后二行
    selected = drop_points
    
    # 倒置打印
    print(f"ORBITAL ENERGIES and Eg = {selected[2][3] - selected[1][3]:.4f} eV")
    print("\n  NO     OCC          E(Eh)            E(eV)")
    for item in reversed(selected):
        print(f"{item[0]:4d}  {item[1]:8.4f}    {item[2]:12.6f}     {item[3]:8.4f}")

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print("使用方法: python command.py filename")
        sys.exit(1)
    
    process_file(sys.argv[1])
