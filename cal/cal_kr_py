#!/bin/env python
import math

# 常量定义
h = 4.1357e-15  # 普朗克常数，单位为 eV·s
c = 3.00e8      # 光速，单位为 m/s
epsilon_0 = 8.854e-12  # 真空介电常数，单位为 C^2/N·m^2

# 输入：能级差（ΔE，单位为 eV）和振子强度（f）
energy_gap_ev = float(input("请输入能级差 ΔE（单位：eV）："))
oscillator_strength = float(input("请输入振子强度 f："))

# 计算跃迁频率 ν（单位：Hz）
nu = energy_gap_ev / h

# 计算跃迁偶极矩平方 |μ_21|^2
# 使用振子强度 f 和频率 ν 的关系式
# mu_squared = (3 * epsilon_0 * h * c * oscillator_strength) / (2 * math.pi**2 * nu)

# 计算爱因斯坦A系数，即辐射跃迁速率 A_21
# A_21 = (8 * math.pi**2 * nu**2) / (3 * epsilon_0 * h * c**3) * mu_squared

# 计算跃迁偶极矩平方 |μ_21|^2
# 使用振子强度 f 和频率 ν 的关系式，使用简化的常数项避免误差
mu_squared = (oscillator_strength * 9.1094e-31 * c * energy_gap_ev * 2) / (6.5821e-16 * math.pi**2)

# 计算爱因斯坦A系数，即辐射跃迁速率 A_21
A_21 = (8 * math.pi**2 * nu**2) / (3 * epsilon_0 * h * c**3) * mu_squared

# 输出结果
print(f"辐射跃迁速率 A_21：{A_21:.2e} s^-1")







# 输出结果
print(f"辐射跃迁速率 A_21：{A_21} s^-1")

