#!/bin/bash

# 脚本说明：
# 本脚本从 Gaussian 计算日志文件中提取前三个 Singlet 和 Triplet 激发态的序号，
# 并生成用于 NTO (Natural Transition Orbitals) 计算的 .gjf 文件。
# 使用方法：
# ./script.sh <chk文件前缀>
# 示例：
# ./script.sh 5  (会处理文件 5.log，输出文件 5_nto.gjf)

# 显示帮助信息
show_help() {
    echo
    echo "用法: $(basename "$0") [pattern.chk]"
    echo
    echo "可选 -n number (1-9) 设置计算 NTO 轨道的单三线态激发态数目 (default is 3)"
    echo
    echo "计算自然跃迁轨道 NTO"
}

# 初始化变量
number=3  # 默认值
filename=""

# 使用 getopts 解析命令行选项
while getopts "n:h" opt; do
  case $opt in
    n)
      number=$OPTARG
      ;;
    h)
      show_help
      exit 0
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      exit 1
      ;;
    :)
      echo "Option -$OPTARG requires an argument." >&2
      exit 1
      ;;
  esac
done

# 移除已处理的选项和它们的参数
shift $((OPTIND -1))


# 输入的 chk 文件前缀和日志文件名
if [ -e "${1/.chk/}.fchk" ]; then
    echo "文件 "${1/.chk/}.fchk" 存在。"
else
    echo "文件 "${1/.chk/}.fchk" 不存在。"
    formchk $1
fi

wait

chk_file_prefix="${1/.chk/}.fchk"
log_file="${chk_file_prefix/.fchk/}.log"
output_file="${chk_file_prefix/.fchk/}_nto.gjf"

echo "log 文件为 ${chk_file_prefix/.fchk/}.log"

# 确保日志文件存在
if [ ! -f "$log_file" ]; then
  echo "Error: $log_file not found!"
  exit 1
fi

# 初始化变量
singlet_states=()
triplet_states=()

# 提取激发态信息
while IFS= read -r line; do
  if [[ $line =~ "Excited State" ]]; then
    # 提取激发态序号、类型
    # echo "$line" | awk '{print $3}'
    # echo "$line" | awk '{print $4}'
    state_number=$(echo "$line" | awk '{print $3}')
    state_type=$(echo "$line" | awk '{print $4}')
    if [[ $state_type == "Singlet"* && ${#singlet_states[@]} -lt ${number} ]]; then
      singlet_states+=("$state_number")
    elif [[ $state_type == "Triplet"* && ${#triplet_states[@]} -lt ${number} ]]; then
      triplet_states+=("$state_number")
    fi
  fi
done < "$log_file"

echo "找到 ${#singlet_states[@]} 个单重态"
echo "找到 ${#triplet_states[@]} 个三重态"


# 检查是否获取到足够的 Singlet 和 Triplet 激发态
if [[ ${#singlet_states[@]} -lt ${number} || ${#triplet_states[@]} -lt ${number} ]]; then
  echo "Warning: Not enough Singlet or Triplet states found in $log_file"
fi

# 设置变量显示激发态
i=0
j=0

# 生成 .gjf 文件
{
  # 处理 Singlet 状态
  for state in "${singlet_states[@]}"; do
    i=$((i+1))
    echo "%OldChk=${chk_file_prefix/.fchk/}.chk"
    echo "%Chk=S$i-${chk_file_prefix/.fchk/}-state${state/:/}"
    echo "%mem=80GB"
    echo "%nprocshared=32"
    echo "# Geom=AllCheck Guess=(Read,Only) Density=(Check,Transition=${state/:/}) Pop=(Minimal,NTO,SaveNTO)"
    echo
    echo "Title Section"
    echo
    echo "--Link1--"
  done

  # 处理 Triplet 状态
  for state in "${triplet_states[@]}"; do
    j=$((j+1))
    echo "%OldChk=${chk_file_prefix/.fchk/}.chk"
    echo "%Chk=T$j-${chk_file_prefix/.fchk/}-state${state/:/}"
    echo "%mem=80GB"
    echo "%nprocshared=32"
    echo "# Geom=AllCheck Guess=(Read,Only) Density=(Check,Transition=${state/:/}) Pop=(Minimal,NTO,SaveNTO)"
    echo
    echo "Title Section"
    echo
    if [[ $j -ne ${number} ]]; then
        echo "--Link1--"
   fi # 正确结束 if 语句
done
} > "$output_file"

echo "" >> "$output_file"
echo "" >> "$output_file"
echo "" >> "$output_file"

echo "NTO .gjf file generated: $output_file"

g16s "$output_file"

exit 0

