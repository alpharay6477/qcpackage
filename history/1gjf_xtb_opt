        print(f"Charge: {charge_mult[0]}, Multiplicity: {charge_mult[1]}")
        print(f"Number of atoms: {len(coords)}")

        write_xyz(charge_mult, coords, output_file)
        print(f"Coordinates written to {output_file}")

	# Run xTB calculation
