#!/bin/env python

import os
import math
import shutil
from collections import defaultdict, deque

# ======================
# 批量计算复合物eda能量分解分析
# 将优化好的复合物log转为gjf文件，会自动处理文件夹下的所有gjf文件
# 将 template.gjf 也放在当前文件夹下
# 需要会使用sobeda分析方法

# for d in */; do [ -d "$d" ] && (cd "$d" && bash sobEDA.sh > eda.txt); done

# 共价半径（Å）
# ======================
COVALENT_RADII = {
    "H": 0.31, "He": 0.28,
    "Li": 1.28, "Be": 0.96, "B": 0.84, "C": 0.76, "N": 0.71, "O": 0.66,
    "F": 0.57, "Ne": 0.58,
    "Na": 1.66, "Mg": 1.41, "Al": 1.21, "Si": 1.11, "P": 1.07,
    "S": 1.05, "Cl": 1.02, "Ar": 1.06,
    "K": 2.03, "Ca": 1.76,
    "Sc": 1.70, "Ti": 1.60, "V": 1.53, "Cr": 1.39,
    "Mn": 1.39, "Fe": 1.32, "Co": 1.26, "Ni": 1.24,
    "Cu": 1.32, "Zn": 1.22,
    "Br": 1.20, "I": 1.39
}

BOND_FACTOR = 1.25


# ======================
# Gaussian 解析
# ======================
def parse_gaussian_input(file_path):
    with open(file_path, 'r') as f:
        lines = f.readlines()

    charge_mult = None
    coords = []
    in_coords = False

    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith('!'):
            continue

        parts = stripped.split()

        if charge_mult is None and len(parts) == 2:
            try:
                charge = int(parts[0])
                mult = int(parts[1])
                if mult >= 1:
                    charge_mult = (charge, mult)
                    in_coords = True
                    continue
            except ValueError:
                pass

        if in_coords and len(parts) >= 4:
            if parts[0][0].isalpha():
                try:
                    coords.append(
                        (parts[0],
                         float(parts[1]),
                         float(parts[2]),
                         float(parts[3]))
                    )
                except ValueError:
                    break

    return charge_mult, coords


# ======================
# 成键与片段识别
# ======================
def distance(a, b):
    return math.sqrt(
        (a[1] - b[1]) ** 2 +
        (a[2] - b[2]) ** 2 +
        (a[3] - b[3]) ** 2
    )


def build_bond_graph(coords):
    graph = defaultdict(list)
    n = len(coords)

    for i in range(n):
        ri = COVALENT_RADII.get(coords[i][0], 0.77)
        for j in range(i + 1, n):
            rj = COVALENT_RADII.get(coords[j][0], 0.77)
            if distance(coords[i], coords[j]) <= BOND_FACTOR * (ri + rj):
                graph[i].append(j)
                graph[j].append(i)
    return graph


def find_fragments(graph, n_atoms):
    visited = [False] * n_atoms
    fragments = []

    for i in range(n_atoms):
        if not visited[i]:
            queue = deque([i])
            visited[i] = True
            frag = [i]  # 存储0-based索引

            while queue:
                v = queue.popleft()
                for nb in graph[v]:
                    if not visited[nb]:
                        visited[nb] = True
                        queue.append(nb)
                        frag.append(nb)

            fragments.append(frag)

    # 按原子个数降序排序（大片段在前）
    fragments.sort(key=lambda x: len(x), reverse=True)

    return fragments


# ======================
# 创建带片段标注的坐标行
# ======================
def create_fragment_annotated_coords(coords, fragments):
    # 创建一个字典，存储每个原子所属的片段编号
    atom_fragment_map = {}
    for frag_idx, fragment in enumerate(fragments, 1):
        for atom_idx in fragment:
            atom_fragment_map[atom_idx] = frag_idx
    
    annotated_lines = []
    for atom_idx, (element, x, y, z) in enumerate(coords):
        frag_num = atom_fragment_map.get(atom_idx, 0)
        if frag_num > 0:
            # 格式化坐标，保持原来的坐标格式
            line = f"{element}(Fragment={frag_num})  {x:>15.10f}  {y:>15.10f}  {z:>15.10f}"
        else:
            line = f"{element}  {x:>15.10f}  {y:>15.10f}  {z:>15.10f}"
        annotated_lines.append(line)
    
    return annotated_lines


# ======================
# 连续编号压缩
# ======================
def compress_indices(indices):
    if not indices:
        return ""

    # 转换为1-based索引
    indices_1based = [i + 1 for i in indices]
    indices_1based.sort()
    
    ranges = []
    start = prev = indices_1based[0]

    for i in indices_1based[1:]:
        if i == prev + 1:
            prev = i
        else:
            ranges.append((start, prev))
            start = prev = i
    ranges.append((start, prev))

    # 将范围格式化为字符串
    parts = []
    for a, b in ranges:
        if a == b:
            parts.append(str(a))
        else:
            parts.append(f"{a}-{b}")

    return ",".join(parts)


# ======================
# 生成新的GJF文件
# ======================
def create_annotated_gjf_file(input_file, coords, fragments, charge_mult):
    # 读取原始文件的所有行
    with open(input_file, 'r') as f:
        lines = f.readlines()
    
    # 获取文件名并创建输出文件名
    base_name = os.path.splitext(input_file)[0]
    output_file = f"{base_name}.gjf"
    
    # 创建带片段标注的坐标行
    annotated_coords = create_fragment_annotated_coords(coords, fragments)
    
    # 写入新文件
    with open(output_file, 'w') as f:
        in_coords_section = False
        coords_written = False
        
        for line in lines:
            stripped = line.strip()
            
            # 如果已经写入了坐标，跳过原始坐标部分
            if coords_written and stripped and stripped[0].isalpha() and len(stripped.split()) >= 4:
                continue
            
            # 检查是否进入坐标部分
            if not in_coords_section and charge_mult and stripped:
                parts = stripped.split()
                if len(parts) == 2:
                    try:
                        int(parts[0])
                        int(parts[1])
                        # 这是电荷和自旋多重度行
                        f.write(line)
                        in_coords_section = True
                        # 写入带片段标注的坐标
                        for coord_line in annotated_coords:
                            f.write(coord_line + "\n")
                        f.write("\n")  # 空行结束坐标部分
                        coords_written = True
                        continue
                    except ValueError:
                        pass
            
            # 写入其他行
            f.write(line)
    
    print(f"Created annotated file: {output_file}")
    return output_file


# ======================
# 主流程
# ======================
def main():
    files = [f for f in os.listdir('.') if f.lower().endswith(('.gjf', '.com'))]

    for file in files:
        base = os.path.splitext(file)[0]

        charge_mult, coords = parse_gaussian_input(file)
        if not coords:
            print(f"File: {file} - No coordinates found")
            continue

        # 识别片段
        graph = build_bond_graph(coords)
        fragments = find_fragments(graph, len(coords))

        filename = os.path.splitext(file)[0]

        print(f"\n{'='*60}")
        print(f"File: {filename}")
        print(f"Total atoms: {len(coords)}")
        print(f"Number of fragments: {len(fragments)}")

        # 为每个片段生成一行压缩后的原子序号，并显示原子个数
        for idx, frag in enumerate(fragments, 1):
            compressed = compress_indices(frag)
            atom_count = len(frag)
            print(f"Fragment {idx} ({atom_count} atoms): {compressed}")

        # 创建带片段标注的GJF文件
        if charge_mult and fragments:
            output_file = create_annotated_gjf_file(file, coords, fragments, charge_mult)
            
            # 显示文件内容预览
            print(f"\nPreview of {output_file}:")
            print("-" * 40)
            with open(output_file, 'r') as f:
                lines = f.readlines()
                # 显示最后几行（坐标部分）
                for line in lines[-min(15, len(lines)):]:
                    if line.strip():
                        print(line.rstrip())
            print("-" * 40)

    print(f"\n{'='*60}")
    print("Processing completed!")
    print("=" * 60)


if __name__ == "__main__":
    main()
