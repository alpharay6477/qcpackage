#!/bin/env python
import sys

def is_float(value):
    try:
        float(value)
        return True
    except ValueError:
        return False
def show_help():
    print("\n计算光谱半峰宽，用法: deal_fl_fwhm_gau [file_spec_gau.log]")
    print("\n如果需要批量处理 [*_spec_gau.log] 请输入 fl_gau11")
    print("")

# 检查命令行参数，如果传入了 -h 或 --help，显示帮助信息并退出
if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
    show_help()
    sys.exit(0)

input_file=sys.argv[1]


# 先检查文件是否包含正常终止信息
with open(input_file, 'r') as infile:
    found_normal_termination = False
    for line in infile:
        if "Normal termination of Gaussian" in line:
            found_normal_termination = True
            break
if not found_normal_termination:
    print(f"错误: {input_file} 计算未正常终止 \n")
    sys.exit(1)


def process_log_file(input_file, output_file="{}spectrum.txt".format(input_file)):
    processing = False
    peak_intensity = 0.0
    wavelengths = []
    intensities = []

    with open(input_file, 'r') as infile, open(output_file, 'w') as outfile:
        # 写入表头

        outfile.write("Wavelength (nm)\tIntensity (microJ.mol^-1)\n")

        for line in infile:
            # 检查是否达到开始处理数据的标志
            if "Intensity: Emitted intensity (in microJ.mol^-1)" in line:
                processing = True
                continue

            # 开始处理数据
            if processing:
                # 检查是否遇到分割线
                if line.strip() == "-----------------------------":
                    if processing == True:
                        processing = "processing"
                    else:
                        break  # 处理结束

                # 仅在有效处理数据时继续
                if processing == "processing":
                    columns = line.split()
                    if len(columns) < 2:
                        continue

                    # 确保波数和强度均为有效浮点数
                    if not (is_float(columns[0]) and is_float(columns[1].replace('D', 'E'))):
                        continue

                    wavenumber = float(columns[0])
                    intensity_str = columns[1].replace('D', 'E')
                    intensity = float(intensity_str)

                    # 计算波长 (nm)，波长 = 1e7 / 波数 (cm^-1)
                    wavelength = 1e7 / wavenumber

                    # 更新峰值强度
                    if intensity > peak_intensity:
                        peak_intensity = intensity

                    # 存储数据
                    wavelengths.append(wavelength)
                    intensities.append(intensity)

                    # 写入波长和强度到输出文件
                    outfile.write(f"{wavelength:.4f}\t{intensity:.10f}\n")

        # 计算半峰强度
        half_peak = peak_intensity / 2

        # 计算半峰宽
        start_wavelength = None
        end_wavelength = None
        max_wavelength = None

        for wavelength, intensity in zip(wavelengths, intensities):
            if max_wavelength is None and intensity == peak_intensity:
                max_wavelength = wavelength
            if start_wavelength is None and intensity >= half_peak:
                start_wavelength = wavelength
            if start_wavelength is not None and end_wavelength is None and intensity < half_peak:
                end_wavelength = wavelength
            if end_wavelength is not None and intensity >= half_peak:
                end_wavelength = wavelength

        half_peak_width = start_wavelength - end_wavelength if start_wavelength and end_wavelength else 0

        if max_wavelength == None:
            max_wavelength = 0.0
     
        # 将半峰宽追加到输出文件
        print(f"处理完成，结果已写入 {output_file}")
        print(f"Peak intensity: {peak_intensity:.2f} microJ.mol^-1  {max_wavelength:.2f}nm")
        print(f"Half Peak Intensity: {half_peak:.2f} microJ.mol^-1  {start_wavelength:.2f}nm  {end_wavelength:.2f}nm")
        print(f"Half Peak Width: {half_peak_width:.2f} nm\n")

    print(f" ")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("请提供输入文件路径")
    else:
        process_log_file(sys.argv[1])

