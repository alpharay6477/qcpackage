#!/bin/bash

# 显示帮助信息
show_help() {
    echo "用法: $(basename "$0") [filename.out]"
    echo "生成 STEOM-CCSD 在 Orca 6.0.1 中计算的 SOC 数值"
    echo "如果提供了文件名，则替换命令中的 *.out 为指定文件"
    echo "如果未提供文件名，则对当前目录下的所有 *.out 文件执行命令"
}

# 检查上一个命令的退出状态
check_error() {
    if [[ $? -ne 0 ]]; then
        echo "错误: $1 失败"
        exit 1
    fi
}

# 如果传入了 -h 或 --help，显示帮助信息并退出
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi


shopt -s extglob
# 如果传入了文件名，则使用该文件，否则使用所有 .log 文件
file_pattern=$(ls !(slurm*).out)
if [[ -n "$1" ]]; then
    file_pattern="$1"
fi

# 计算传入文件数量
file_num=$(ls -1 ${file_pattern} 2>/dev/null | wc -l)

# 如果没有文件，退出脚本
if [[ $file_num -eq 0 ]]; then
    echo "没有找到匹配的 .log 文件。"
    exit 1
fi

#!/bin/bash

if ls slurm-* 1> /dev/null 2>&1; then
    rm slurm-*
fi

# 删除 sub_*sbatch 文件
if ls sub_*sbatch 1> /dev/null 2>&1; then
    rm sub_*sbatch
fi



soc() {
     awk 'BEGIN {
    printf "%-6s", "T\\S";
    for (s=0; s<=6; s++) printf "%-8s", s;
    print ""
}
{
    if($0 ~/<T|HSO|S>/) readf=1
    if(readf==1 && $0 ~/T      S/) {readf=2}
    if(readf==2 && $0 ~/-----/) {readf=3; getline}
    if(readf==3 && $0 ~/SOC stabilization/) {readf=0}
    if(readf==3 && NF > 2) {
        t=$1; s=$2
        soc=(($4)^2 + ($6)^2 + ($9)^2 + ($11)^2 + ($14)^2 + ($16)^2)^0.5
        data[t][s] = soc
        if (t > max_t) max_t = t
        if (s > max_s) max_s = s
    }
}
END {
    for (t=1; t<=max_t; t++) {
        printf "%-6d", t
        for (s=0; s<=max_s; s++) {
            printf "%-8.3f", (t in data && s in data[t]) ? data[t][s] : 0.00
        }
        print ""
    }
}' $1
}


for i in $file_pattern; do
        echo ""
	echo $i
	soc $i
	echo ""
done

