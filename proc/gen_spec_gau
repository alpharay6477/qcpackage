#!/bin/env python
import re
import sys
import os
import numpy as np
import glob
import matplotlib.pyplot as plt
from matplotlib.ticker import AutoMinorLocator

def is_float(value):
    """检查字符串是否可以转换为浮点数"""
    try:
        float(value)
        return True
    except ValueError:
        return False

def process_log_file(input_file, output_file=None):
    """处理log文件，提取光谱数据并保存到文件"""
    # 如果没有指定输出文件，使用默认命名
    if output_file is None:
        output_file = f"{os.path.splitext(input_file)[0]}_spectrum.txt"
    
    processing = False
    peak_intensity = 0.0
    wavelengths = []
    intensities = []

    try:
        with open(input_file, 'r') as infile, open(output_file, 'w') as outfile:
            # 写入表头
            outfile.write("Wavelength (nm)\tIntensity (microJ.mol^-1)\n")

            for line in infile:
                # 检查是否达到开始处理数据的标志
                if "Intensity: Emitted intensity (in microJ.mol^-1)" in line:
                    processing = True
                    continue

                # 开始处理数据
                if processing:
                    # 检查是否遇到分割线
                    if line.strip() == "-----------------------------":
                        if processing == True:
                            processing = "processing"
                        else:
                            break  # 处理结束

                    # 仅在有效处理数据时继续
                    if processing == "processing":
                        columns = line.split()
                        if len(columns) < 2:
                            continue

                        # 确保波数和强度均为有效浮点数
                        if not (is_float(columns[0]) and is_float(columns[1].replace('D', 'E'))):
                            continue

                        wavenumber = float(columns[0])
                        intensity_str = columns[1].replace('D', 'E')
                        intensity = float(intensity_str)

                        # 计算波长 (nm)，波长 = 1e7 / 波数 (cm^-1)
                        wavelength = 1e7 / wavenumber

                        # 更新峰值强度
                        if intensity > peak_intensity:
                            peak_intensity = intensity

                        # 存储数据
                        wavelengths.append(wavelength)
                        intensities.append(intensity)

                        # 写入波长和强度到输出文件
                        outfile.write(f"{wavelength:.4f}\t{intensity:.10f}\n")
    except Exception as e:
        print(f"    错误: 处理文件时出错 - {e}")
        return None, [], []
    
    return output_file, wavelengths, intensities

def process_log_for_transitions(file_path):
    """处理log文件，提取跃迁信息（仅用于获取波长和DipStr）"""
    # 初始化变量
    zero_zero_energy = 0.0
    zero_zero_energy_nm = 0.0
    transitions = []
    
    # 读取文件
    try:
        with open(file_path, 'r', encoding='utf-8') as file:
            content = file.read()
    except UnicodeDecodeError:
        with open(file_path, 'r', encoding='latin-1') as file:
            content = file.read()
    
    # 提取0-0 transition能量
    zero_zero_match = re.search(r'Energy of the 0-0 transition:\s*([\d.]+)\s*cm\^\(-1\)', content)
    if zero_zero_match:
        zero_zero_energy = float(zero_zero_match.group(1))
        zero_zero_energy_nm = 1e7 / zero_zero_energy
    
    # 提取所有transition信息
    transition_pattern = r'Energy =\s*([-\d.]+)\s*cm\^-1:\s*\|([^>]+)>\s*->\s*\|([^>]+)>.*?Intensity =\s*([\d.E+-]+).*?DipStr =\s*([\d.E+-]+)'
    
    transition_matches = re.finditer(transition_pattern, content, re.DOTALL)
    
    for match in transition_matches:
        try:
            energy_relative = float(match.group(1))
            initial_state = match.group(2).strip()
            final_state = match.group(3).strip()
            intensity = match.group(4)
            dip_str = match.group(5)
            
            # 计算绝对能量
            energy_absolute = zero_zero_energy + energy_relative
            # 转换为nm
            wavelength_nm = 1e7 / energy_absolute
            
            transitions.append({
                'Energy (cm^-1)': energy_absolute,
                'Wavelength (nm)': wavelength_nm,
                'Initial State': initial_state,
                'Final State': final_state,
                'Intensity': intensity,
                'DipStr': dip_str
            })
        except (ValueError, AttributeError) as e:
            continue
    
    # 如果没有找到，尝试简单格式
    if not transitions:
        # 尝试查找简单的能量和振子强度
        simple_pattern = r'([\d.]+)\s*cm\^-1.*?DipStr\s*=\s*([\d.E+-]+)'
        matches = re.finditer(simple_pattern, content)
        for match in matches:
            try:
                energy_absolute = float(match.group(1))
                dip_str = match.group(2)
                wavelength_nm = 1e7 / energy_absolute
                
                transitions.append({
                    'Energy (cm^-1)': energy_absolute,
                    'Wavelength (nm)': wavelength_nm,
                    'Initial State': 'Unknown',
                    'Final State': 'Unknown',
                    'Intensity': '0.0',
                    'DipStr': dip_str
                })
            except (ValueError, IndexError):
                continue
    
    return zero_zero_energy_nm, transitions

def plot_spectrum_with_dipstr(data, output_dir="plots"):
    """绘制双Y轴光谱图：DipStr为垂线，光谱强度为连续线"""
    
    # 创建输出目录
    os.makedirs(output_dir, exist_ok=True)
    
    filename = data['filename']
    dipstr_wavelengths = data['wavelengths']
    dipstr_values = data['dipstr']
    spectrum_wavelengths = data['spectrum_wavelengths']
    spectrum_intensities = data['spectrum_intensities']
    
    # 创建图形和双Y轴
    fig, ax1 = plt.subplots(figsize=(12, 6))
    ax2 = ax1.twinx()
    
    # 设置标题
    title_name = os.path.splitext(filename)[0]
    plt.title(f"Spectrum and DipStr for {title_name}", fontsize=14, fontweight='bold')
    
    # 绘制光谱线（左Y轴）
    color1 = 'tab:blue'
    ax1.plot(spectrum_wavelengths, spectrum_intensities, 
             color=color1, linewidth=2, alpha=0.8, label='Spectrum')
    ax1.set_xlabel('Wavelength (nm)', fontsize=12)
    ax1.set_ylabel('Intensity (microJ.mol$^{-1}$)', fontsize=12, color=color1)
    ax1.tick_params(axis='y', labelcolor=color1)
    ax1.grid(True, alpha=0.3, linestyle='--')
    
    # 绘制DipStr垂线（右Y轴）
    color2 = 'tab:red'
    if len(dipstr_wavelengths) > 0:
        # 归一化DipStr值用于显示高度
        if dipstr_values.max() > 0:
            normalized_dipstr = dipstr_values / dipstr_values.max() * spectrum_intensities.max() * 0.8
        else:
            normalized_dipstr = np.zeros_like(dipstr_values)
        
        # 绘制垂线
        for wl, height in zip(dipstr_wavelengths, normalized_dipstr):
            ax2.vlines(wl, 0, height, color=color2, linewidth=2, alpha=0.7, linestyle='-')
        
        # 绘制DipStr点
        ax2.scatter(dipstr_wavelengths, normalized_dipstr, 
                   color=color2, s=30, alpha=0.8, label='DipStr')
    
    ax2.set_ylabel('Normalized DipStr', fontsize=12, color=color2)
    ax2.tick_params(axis='y', labelcolor=color2)
    
    # 设置X轴范围（自动调整）
    if len(spectrum_wavelengths) > 0:
        x_min = min(spectrum_wavelengths.min(), dipstr_wavelengths.min() if len(dipstr_wavelengths) > 0 else spectrum_wavelengths.min())
        x_max = max(spectrum_wavelengths.max(), dipstr_wavelengths.max() if len(dipstr_wavelengths) > 0 else spectrum_wavelengths.max())
        # 添加一些边距
        x_range = x_max - x_min
        ax1.set_xlim(x_min - 0.05*x_range, x_max + 0.05*x_range)
    
    # 设置Y轴范围
    if len(spectrum_intensities) > 0:
        y_max = spectrum_intensities.max()
        ax1.set_ylim(0, y_max * 1.1)
    
    # 添加图例
    lines1, labels1 = ax1.get_legend_handles_labels()
    lines2, labels2 = ax2.get_legend_handles_labels()
    ax1.legend(lines1 + lines2, labels1 + labels2, loc='upper right', fontsize=10)
    
    # 添加网格和小刻度
    ax1.xaxis.set_minor_locator(AutoMinorLocator())
    ax1.yaxis.set_minor_locator(AutoMinorLocator())
    
    # 调整布局
    plt.tight_layout()
    
    # 保存图形
    output_file = os.path.join(output_dir, f"{title_name}_spectrum_plot.png")
    plt.savefig(output_file, dpi=300, bbox_inches='tight')
    plt.close(fig)
    
    print(f"    图形已保存: {output_file}")
    return output_file

def create_combined_spectra_file(file_list, output_file="combined_spectra.txt", make_plots=False):
    """创建合并的光谱文件，每个文件对应四列数据"""
    
    all_data = []
    plot_files = []
    
    print(f"开始处理 {len(file_list)} 个文件...")
    
    # 处理每个文件
    for file_idx, file_path in enumerate(file_list, 1):
        filename = os.path.basename(file_path)
        print(f"  [{file_idx}/{len(file_list)}] 处理: {filename}")
        
        # 首先提取原始跃迁信息（用于原始波长和DipStr）
        zero_zero_energy_nm, transitions = process_log_for_transitions(file_path)
        
        if not transitions:
            print(f"    警告: 没有找到跃迁数据")
            continue
        
        print(f"    找到 {len(transitions)} 个跃迁")
        
        # 提取波长和DipStr
        wavelengths = np.array([t['Wavelength (nm)'] for t in transitions])
        dipstr_values = np.array([float(t['DipStr']) for t in transitions])
        
        # 处理光谱数据（使用你提供的函数）
        spectrum_file, spectrum_wavelengths, spectrum_intensities = process_log_file(file_path)
        
        if spectrum_file is None or not spectrum_wavelengths:
            print(f"    警告: 没有找到光谱数据")
            continue
        
        print(f"    生成光谱数据: {os.path.basename(spectrum_file)}")
        print(f"    光谱数据点数: {len(spectrum_wavelengths)}")
        
        # 准备数据
        data_dict = {
            'filename': filename,
            'wavelengths': wavelengths,
            'dipstr': dipstr_values,
            'spectrum_wavelengths': spectrum_wavelengths,
            'spectrum_intensities': spectrum_intensities
        }
        
        # 添加到总数据
        all_data.append(data_dict)
        
        # 如果需要绘图
        if make_plots:
            try:
                plot_file = plot_spectrum_with_dipstr(data_dict)
                plot_files.append(plot_file)
            except Exception as e:
                print(f"    警告: 绘图时出错 - {e}")
    
    if not all_data:
        print("错误: 没有找到任何有效数据")
        return None
    
    print(f"生成合并文件: {output_file}")
    
    # 写入合并文件
    with open(output_file, 'w', encoding='utf-8') as f:
        # 写入表头（第一行）
        header_parts = []
        for data in all_data:
            header_parts.extend([
                f"{data['filename']}_原始波长(nm)",
                f"{data['filename']}_DipStr",
                f"{data['filename']}_光谱波长(nm)",
                f"{data['filename']}_光谱强度"
            ])
        f.write("\t".join(header_parts) + "\n")
        
        # 确定最大行数（考虑原始跃迁和光谱数据）
        max_transitions = max(len(data['wavelengths']) for data in all_data)
        max_spectrum = max(len(data['spectrum_wavelengths']) for data in all_data)
        max_rows = max(max_transitions, max_spectrum)
        
        print(f"    最大跃迁数: {max_transitions}")
        print(f"    最大光谱点数: {max_spectrum}")
        
        # 写入数据行
        for i in range(max_rows):
            line_parts = []
            
            # 每个文件的数据
            for data in all_data:
                # 原始波长和DipStr
                if i < len(data['wavelengths']):
                    line_parts.extend([
                        f"{data['wavelengths'][i]:.2f}",
                        f"{data['dipstr'][i]:.6E}"
                    ])
                else:
                    line_parts.extend(["", ""])
                
                # 光谱波长和强度数据
                if i < len(data['spectrum_wavelengths']):
                    line_parts.extend([
                        f"{data['spectrum_wavelengths'][i]:.4f}",
                        f"{data['spectrum_intensities'][i]:.10f}"
                    ])
                else:
                    line_parts.extend(["", ""])
            
            f.write("\t".join(line_parts) + "\n")
    
    if make_plots and plot_files:
        print(f"    生成了 {len(plot_files)} 个图形文件")
    
    return output_file

def main():
    """主函数"""
    # 检查命令行参数和选项
    make_plots = False
    input_path = None
    
    # 解析命令行参数
    for arg in sys.argv[1:]:
        if arg == '-p' or arg == '--plot':
            make_plots = True
        elif not arg.startswith('-'):
            input_path = arg
    
    # 获取文件列表
    if input_path:
        if os.path.isfile(input_path):
            # 单个文件
            file_list = [input_path]
        elif os.path.isdir(input_path):
            # 文件夹
            file_list = glob.glob(os.path.join(input_path, "*.log"))
            if not file_list:
                print(f"在文件夹 {input_path} 中没有找到.log文件")
                sys.exit(1)
        else:
            print(f"路径不存在: {input_path}")
            sys.exit(1)
    else:
        # 默认处理当前文件夹下的所有log文件
        file_list = glob.glob("*.log")
        if not file_list:
            print("当前文件夹中没有找到.log文件")
            sys.exit(1)
    
    print(f"找到 {len(file_list)} 个log文件")
    if make_plots:
        print("绘图功能已启用")
    
    # 创建合并的光谱文件
    output_file = create_combined_spectra_file(file_list, make_plots=make_plots)
    
    if output_file:
        print(f"\n处理完成！")
        print(f"合并的光谱数据已保存到: {output_file}")
        if make_plots:
            print(f"图形文件已保存到: plots/ 目录")
        print(f"\n文件格式说明:")
        print(f"  每个文件对应四列数据:")
        print(f"    1. 原始波长(nm) - 从跃迁信息中提取")
        print(f"    2. DipStr - 从跃迁信息中提取")
        print(f"    3. 光谱波长(nm) - 从光谱文件中读取")
        print(f"    4. 光谱强度 - 从光谱文件中读取")
        print(f"\n使用说明:")
        print(f"  运行脚本时不加参数: python {sys.argv[0]} [文件或文件夹]")
        print(f"  启用绘图功能: python {sys.argv[0]} [文件或文件夹] -p")
        print(f"  或: python {sys.argv[0]} [文件或文件夹] --plot")
    else:
        print("处理失败，没有生成输出文件")

if __name__ == "__main__":
    main()
