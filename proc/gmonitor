#!/bin/bash

LOG_FILE=$1
if [ ! -f "$LOG_FILE" ]; then echo "用法: ./gmonitor.sh <logfile>"; exit 1; fi

echo $1

scf_count=$(grep "SCF Done" "$1" | wc -l)

# 判断是否小于 2
if [ "$scf_count" -lt 2 ]; then
    echo "步数太少"
    exit 1
fi

# --- 1. 定义收敛阈值 ---
THR_MF=0.000450; THR_RF=0.000300; THR_MD=0.001800; THR_RD=0.001200

DATA_FILE=$(mktemp)
trap 'rm -f "$DATA_FILE"' EXIT

# --- 2. 健壮的数据提取逻辑 ---
# 提取所有优化步的四个收敛参数 (作为主轴)
grep "Maximum Force" "$LOG_FILE" | awk '{print $3}' > mf.tmp
grep "RMS     Force" "$LOG_FILE" | awk '{print $3}' > rf.tmp
grep "Maximum Displacement" "$LOG_FILE" | awk '{print $3}' > md.tmp
grep "RMS     Displacement" "$LOG_FILE" | awk '{print $3}' > rd.tmp

# 提取能量：为了防止 paste 错位，我们使用 grep 的行号功能或确保数量匹配
# 基态能量 (SCF Done)
grep "SCF Done" "$LOG_FILE" | awk '{print $5}' > e_gs.tmp
# 激发态能量 (Total Energy, E) - 如果不存在则生成空文件
grep "Total Energy, E" "$LOG_FILE" | awk '{print $5}' > e_es.tmp

# --- 关键步骤：处理行数不一致 ---
# 取参数行数作为最大步数
MAX_STEPS=$(wc -l < mf.tmp)

# 格式化函数：确保能量文件行数与参数行数一致（不足补空，多余截断）
adjust_rows() {
    local file=$1
    local target_rows=$2
    local count=$(wc -l < "$file")
    if [ "$count" -lt "$target_rows" ]; then
        # 如果能量行数少（例如最后一步没算完），补问号或空位
        for ((i=count+1; i<=target_rows; i++)); do echo "NaN"; done >> "$file"
    elif [ "$count" -gt "$target_rows" ]; then
        # 如果能量行数多（例如扫描计算），截断
        head -n "$target_rows" "$file" > "${file}.bak" && mv "${file}.bak" "$file"
    fi
}

adjust_rows e_gs.tmp "$MAX_STEPS"
adjust_rows e_es.tmp "$MAX_STEPS"

# 合并数据: Step(1) MF(2) RF(3) MD(4) RD(5) E_GS(6) E_ES(7)
# 归一化处理在 paste 后的 awk 中完成
paste mf.tmp rf.tmp md.tmp rd.tmp e_gs.tmp e_es.tmp | awk -v t1=$THR_MF -v t2=$THR_RF -v t3=$THR_MD -v t4=$THR_RD \
'{print NR, $1/t1, $2/t2, $3/t3, $4/t4, $5, $6}' > "$DATA_FILE"


# 检查是否存在激发态数据
HAS_ES=$(grep -v "NaN" e_es.tmp | wc -l)

# --- 3. 终端绘图 ---
gnuplot << EOF

stats "$DATA_FILE" using 1 nooutput
set xrange [0:STATS_max + 5]

set terminal dumb ansi size $(tput cols), 32
set border
unset grid
set tics scale 0


# --- A. 能量趋势图 ---
unset logscale y
set key top right
set key samplen 0.2
set key spacing 1.0
set title "Total Energy Trend (Hartree)"
set ylabel "Energy (H)"
# 使用autoscale然后调整
set autoscale y
set offset 0, 0, graph 0.05, graph 0.05
if ($HAS_ES > 0) {
    plot "$DATA_FILE" using 1:7 with points pt '*' lc rgb "yellow" title "ES Energy", \
         "$DATA_FILE" using 1:6 with points pt '*' lc rgb "blue"   title "GS Energy"
} else {
    plot "$DATA_FILE" using 1:6 with points pt '*' lc rgb "blue" title "GS Energy"
}


# --- B. 归一化收敛图 ---
set title "Normalized Convergence (Value < 1 means Converged)"
set key left bottom vertical
set key samplen 0.5
set key spacing 1.2
set ylabel "Ratio"
set logscale y
set yrange [0.001:1000]
set arrow from graph 0, first 0.5 to graph 1, first 0.5 nohead lc rgb "white"

plot "$DATA_FILE" u 1:2 with points pt '*' lc rgb "red"     title "Max Force", \
     "$DATA_FILE" u 1:3 with points pt '*' lc rgb "blue"    title "RMS Force", \
     "$DATA_FILE" u 1:4 with points pt '·' lc rgb "red"   title "Max Disp ", \
     "$DATA_FILE" u 1:5 with points pt '·' lc rgb "blue" title "RMS Disp "


EOF

# 打印表头
printf "%-6s %6s %6s %6s %6s %15s %15s\n" "Steps" "MF" "RF" "MD" "RD" "Energy" "(Energy-td)"

# 直接使用 awk 打印最后一行并格式化 (无需 read 和 多个 printf)
tail -n 3 "$DATA_FILE" | awk '{
    printf "%-6s %6.2f %6.2f %6.2f %6.2f %15.5f %15.5f\n", $1, $2, $3, $4, $5, $6, $7
}'
echo ""

rm  mf.tmp rf.tmp md.tmp rd.tmp e_gs.tmp e_es.tmp

