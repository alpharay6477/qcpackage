#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
command.py

将 ORCA 输入文件 (.inp) 中的内联坐标块替换为引用外部 .xyz 文件的形式，
并自动生成对应的 .xyz 文件。

用法:
    python command.py                     # 处理当前目录下所有 .inp 文件
    python command.py file1.inp file2.inp ...  # 处理指定的 .inp 文件

示例输入 (file.inp):
    ! RIJCOSX B3LYP/G def2-SVP def2/J OPT D3BJ nopop
    %pal nprocs 30
         end
    %MaxCore 2730
    * xyz 0 1
    C   -4.69657565181724 -2.89552183951317 1.12064822395372
    H   -4.37616788766586 -0.39099117874524 6.75018983529109
    ...
    *
    
输出:
    - 修改后的 file.inp（坐标块替换为 "* xyzfile 0 1 file.xyz *"）
    - 新生成的 file.xyz（包含原子符号和坐标）

注意:
    - 原始 .inp 文件会被覆盖，请确保已备份重要数据。
    - 只处理包含 "* xyz 0 1" 的 .inp 文件。
"""

import os
import sys
import argparse
import glob

def process_inp_file(inp_path):
    """
    处理单个 .inp 文件：
    1. 提取坐标块
    2. 写入 .xyz 文件
    3. 替换 .inp 中的坐标块为 xyzfile 引用
    """
    if not os.path.isfile(inp_path):
        print(f"警告: 文件不存在，跳过: {inp_path}")
        return

    with open(inp_path, 'r', encoding='utf-8') as f:
        lines = f.readlines()

    # 查找 "* xyz 0 1" 开始行和结束的 "*"
    start_idx = None
    end_idx = None
    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped == "* xyz 0 1":
            start_idx = i
        elif start_idx is not None and stripped == "*":
            end_idx = i
            break

    if start_idx is None or end_idx is None:
        print(f"跳过（未找到 '* xyz 0 1' 坐标块）: {inp_path}")
        return

    # 提取坐标行（不包括 "* xyz 0 1" 和结尾的 "*"）
    coord_lines = lines[start_idx + 1:end_idx]
    if not coord_lines:
        print(f"警告: 坐标块为空，跳过: {inp_path}")
        return

    # 准备 .xyz 文件内容
    atom_count = len(coord_lines)
    xyz_content = [f"{atom_count}\n", "Generated by command.py\n"]
    for line in coord_lines:
        parts = line.split()
        if len(parts) < 4:
            print(f"警告: 坐标行格式错误，跳过该行: {line.strip()}")
            continue
        atom = parts[0]
        x, y, z = parts[1], parts[2], parts[3]
        xyz_content.append(f"{atom}       {x}  {y}  {z}\n")

    # 生成 .xyz 文件名
    base_name = os.path.splitext(inp_path)[0]
    xyz_path = base_name + ".xyz"

    # 写入 .xyz 文件
    try:
        with open(xyz_path, 'w', encoding='utf-8') as f:
            f.writelines(xyz_content)
        print(f"已生成: {xyz_path}")
    except Exception as e:
        print(f"写入 .xyz 文件失败: {xyz_path}, 错误: {e}")
        return

    # 构建新的 .inp 内容：保留前部分 + 替换为 xyzfile 行 + 保留结尾部分（如果有）
    new_lines = lines[:start_idx]
    xyzfile_line = f"* xyzfile 0 1 {os.path.basename(xyz_path)} *\n"
    new_lines.append(xyzfile_line)
    # 如果原文件在 "*" 之后还有内容，也保留（虽然 ORCA 通常不会）
    if end_idx + 1 < len(lines):
        new_lines.extend(lines[end_idx + 1:])

    # 覆盖原 .inp 文件
    try:
        with open(inp_path, 'w', encoding='utf-8') as f:
            f.writelines(new_lines)
        print(f"已更新: {inp_path}")
    except Exception as e:
        print(f"更新 .inp 文件失败: {inp_path}, 错误: {e}")

def main():
    parser = argparse.ArgumentParser(
        description="将 ORCA .inp 文件中的内联坐标替换为外部 .xyz 文件引用，并生成 .xyz 文件。",
        formatter_class=argparse.RawTextHelpFormatter,
        epilog="示例:\n"
               "  python command.py\n"
               "  python command.py molecule.inp\n"
               "  python command.py *.inp"
    )
    parser.add_argument(
        "files",
        nargs="*",
        help="要处理的 .inp 文件路径。若未指定，则处理当前目录下所有 .inp 文件。"
    )
    args = parser.parse_args()

    if not args.files:
        # 默认处理当前目录所有 .inp
        inp_files = glob.glob("*.inp")
        if not inp_files:
            print("当前目录下没有找到 .inp 文件。")
            return
        print(f"检测到 {len(inp_files)} 个 .inp 文件，开始处理...")
    else:
        # 展开通配符（如 Windows 不自动展开）
        inp_files = []
        for pattern in args.files:
            matched = glob.glob(pattern)
            if matched:
                inp_files.extend(matched)
            else:
                # 如果没有匹配，仍加入（后续会报“文件不存在”）
                inp_files.append(pattern)

    for inp_file in inp_files:
        process_inp_file(inp_file)

if __name__ == "__main__":
    main()


