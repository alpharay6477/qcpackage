#!/bin/bash

# 显示帮助信息
show_help() {
    echo "用法 : $(basename "$0") [filename] "
    echo ""
    echo "替换文本内容，需要在命令中编辑需要替换的内容"
    echo ""
}

# 检查上一个命令的退出状态
check_error() {
    if [[ $? -ne 0 ]]; then
        echo "错误: $1 失败"
    fi
}

# 如果传入了 -h 或 --help，显示帮助信息并退出
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi
# 检查是否提供了文件参数
if [ -z "$1" ]; then
  echo "Usage: $0 <filename>"
  exit 1
fi

# 定义要查找的多行文本
SEARCH_TEXT=$(cat <<'EOF'
! RIJCOSX RI-mPW2PLYP def2-SVP def2/J def2-SVP/C TIGHTSCF
%tddft
dcorr 1
nroots 5
triplets true
DoNTO true
NTOStates 1,2,3
NTOThresh 1e-4
tda true
printlevel 3
end
%mp2 density relaxed end
EOF
)

# 定义要替换的多行文本
REPLACE_TEXT=$(cat <<'EOF'
! STEOM-DLPNO-CCSD def2-SVP def2/J def2-SVP/C TIGHTSCF
%mdci
  NRoots 6
  DoRootWise true
  OThresh 0.01
  VThresh 0.01
  TCutPNOSingles 1e-11
  NDAV 400
  DoStoreSTEOM true
  DoSimpleDens false
  AddL2Term True
  DTol 1e-4
  DoTriplet true
  STEOMSOC true
end
EOF
)

# 临时文件
TMP_FILE=$(mktemp)

# 使用 awk 进行多行查找和替换
awk -v search="$SEARCH_TEXT" -v replace="$REPLACE_TEXT" '
BEGIN {
  # 将查找文本和替换文本按行分割成数组
  split(search, search_lines, "\n")
  split(replace, replace_lines, "\n")
  search_count = length(search_lines)
  replace_count = length(replace_lines)
}

{
  # 检查当前行是否匹配查找文本的第一行
  if ($0 == search_lines[1]) {
    # 检查接下来的行是否匹配查找文本的剩余行
    matched = 1
    for (i = 2; i <= search_count; i++) {
      getline next_line
      if (next_line != search_lines[i]) {
        matched = 0
        break
      }
    }
    # 如果匹配成功，输出替换文本
    if (matched) {
      for (i = 1; i <= replace_count; i++) {
        print replace_lines[i]
      }
    } else {
      # 如果不匹配，输出原始行
      print $0
      for (i = 1; i < search_count; i++) {
        print next_line
      }
    }
  } else {
    print $0
  }
}
' "$1" > "$TMP_FILE"

# 将临时文件内容覆盖原文件
mv "$TMP_FILE" "$1"

echo "替换完成"


